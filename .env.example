# Copy to .env and fill in. .env is gitignored — never commit it.

# --- Postgres ---
POSTGRES_DB=critters
POSTGRES_USER=critters
# Required. Generate one: openssl rand -hex 24
POSTGRES_PASSWORD=

# --- App ---
# Host port to expose the app on. The container always listens on 8080; this only
# changes the host side, e.g. set APP_PORT=8090 if 8080 is already in use.
APP_PORT=8080
# Host interface to bind that port to. Default 127.0.0.1 = reachable only on this
# machine (no LAN). Set to 0.0.0.0 to expose the app to your LAN. The Cloudflare
# tunnel does not use this — it reaches the app over the docker network (app:8080).
APP_BIND=127.0.0.1
# Credentials for write actions (POST/DELETE /api/sightings). Reads are public.
# If either is blank, write endpoints return 503 "writes disabled".
WRITE_USER=
WRITE_PASSWORD=
TIMEZONE=America/New_York

# --- Push notifications (optional) ---
# Generate the key pair once: npx web-push generate-vapid-keys
# Rotating keys invalidates every existing subscription — treat like the DB password.
# All three must be set, or push stays disabled (bell hidden, /api/push/* return 503).
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Contact for push services, e.g. mailto:you@example.com
VAPID_SUBJECT=

# --- Emoji-request alerts (optional) ---
# Get a phone push when someone requests an emoji, to you only. Install the ntfy
# app, subscribe to a secret/unguessable topic, and put its URL here. Unset =
# disabled (the request is still saved to the owner-only list either way).
# The topic name IS the secret on the public server, so make it long + random.
# NTFY_URL=https://ntfy.sh/natalie-requests-<long-random-string>
NTFY_URL=

# --- Public site ---
# Absolute origin used for URLs in the RSS feed (no trailing slash).
SITE_URL=https://nataliesawacritter.info

# --- Local dev (pnpm dev:server outside docker) ---
# DATABASE_URL=postgres://critters:<POSTGRES_PASSWORD>@localhost:5432/critters

# --- Cloudflare tunnel (prod only; docker compose --profile tunnel up -d) ---
CLOUDFLARE_TUNNEL_TOKEN=

# --- Emoji-request sidecar (optional; docker compose --profile sidecar up -d) ---
# Turns emoji requests into pull requests (original art only; never merges).
# Off unless you start the profile. Reuses WRITE_USER/WRITE_PASSWORD (above) to
# read/mark requests. If ANTHROPIC_API_KEY / GH_TOKEN are blank it refuses to start.
ANTHROPIC_API_KEY=
# Fine-grained PAT: this repo only, Contents + Pull requests read/write. NOT merge.
GH_TOKEN=
REPO_SLUG=JamesAwesome/nataliesawacritter.info
SIDECAR_MODEL=sonnet
SIDECAR_POLL_INTERVAL_MS=60000
# Set to 1 to only log what it would do (no agent runs, no writes).
SIDECAR_DRY_RUN=
